# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vercel Blob is where edited recipes, the trash, the audit log, and all
# backup snapshots live in production. Create a Blob store at vercel.com,
# then run `vercel env pull` (or copy the token here for local dev).
# Without this, the app still works but edits only live in-memory and are
# lost on server restart.
BLOB_READ_WRITE_TOKEN=

# Admin credentials. Defaults are set in src/lib/auth.ts so the app is
# usable out of the box. Override here in any environment where you'd
# like different values.
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Secret used to sign the admin session cookie. Set this in production to
# anything long and random; rotating it invalidates every active session.
SESSION_SECRET=
