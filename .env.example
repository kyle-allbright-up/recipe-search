# Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Vercel Blob is where all persistent data lives: the recipes store,
# users store, audit logs, and backup snapshots. Create a Blob store
# at vercel.com, then run `vercel env pull` (or copy the token here for
# local dev). Without this, the app still works but every write only
# lives in-memory and is lost on server restart.
BLOB_READ_WRITE_TOKEN=

# Secret used to sign the user session cookie. Set this in production
# to anything long and random; rotating it invalidates every active
# session. Defaults to a public dev value if unset.
SESSION_SECRET=
